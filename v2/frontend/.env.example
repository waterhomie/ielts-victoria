# Examiner Victoria V2 frontend environment example
#
# For local development, leave VITE_API_BASE empty so the Vite dev server
# proxies /api calls to the backend. This also works behind HTTPS tunnels.
# For deployment, set this to the public FastAPI backend URL.

VITE_API_BASE=
VITE_PROXY_TARGET=http://127.0.0.1:8010
